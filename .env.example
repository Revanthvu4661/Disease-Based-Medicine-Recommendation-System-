MONGO_URI=mongodb://localhost:27017/MediCare
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
PORT=5000
NODE_ENV=development

# If true, server will still start even if MongoDB is disconnected.
# For launch / production you should keep this unset/false.
ALLOW_DB_DISCONNECTED=false

# Google OAuth — Get from https://console.cloud.google.com/
# Create a project → APIs & Services → Credentials → OAuth 2.0 Client ID (Web application)
# Add http://localhost:5000 to Authorized JavaScript origins
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
